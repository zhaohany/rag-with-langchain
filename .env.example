# App
RAG_APP_NAME=rag-with-langchain
RAG_APP_VERSION=0.1.0
RAG_ENV=local

# API
RAG_API_HOST=127.0.0.1
RAG_API_PORT=8000
RAG_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Data
RAG_RAW_DOCS_DIR=data/raw_docs
RAG_INDEX_PATH=data/index
RAG_METADATA_PATH=data/meta
RAG_SYSTEM_META_PATH=data/system/system_meta.json

# RAG
RAG_TOP_K=4
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=80

# Model backend (future-ready)
RAG_MODEL_BACKEND=local
RAG_LLM_MODEL=
RAG_EMBEDDING_MODEL=

# Future (optional)
RAG_MLFLOW_TRACKING_URI=
RAG_VLLM_BASE_URL=
